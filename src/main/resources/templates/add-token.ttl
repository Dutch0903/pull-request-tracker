<t:dock xmlns:t="https://github.com/KyleKreuter/tamboui-spring/template">
  <t:dialog region="center" title="Add token"
            border-type="rounded" border-color="yellow"
            width="100" padding="1"
            direction="vertical" spacing="1">

    <t:form-field label="Name" bind="nameInput"
                    placeholder="Name"
                    border-type="rounded" border-color="dark-gray"
                    focused-border-color="cyan" label-width="12" />

    <t:form-field label="Token" bind="tokenInput"
                        placeholder="Token"
                        border-type="rounded" border-color="dark-gray"
                        focused-border-color="cyan" label-width="12" />

    <t:if test="error.length() > 0">
      <t:text t:text="Failed to add token:" class="text-red" />
      <t:text t:text="${error}" class="text-red" />
    </t:if>
  </t:dialog>

    <t:include template="keybindings" />
</t:dock>